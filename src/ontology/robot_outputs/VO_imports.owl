    <!-- http://purl.obolibrary.org/obo/OBI_0600007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OBI_0600007">
        <obo:IAO_0000115 xml:lang="en">A process by which a substance is intentionally given to an organism resulting in exposure of the organism to that substance.</obo:IAO_0000115>
        <rdfs:label xml:lang="en">administering substance in vivo</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/VO_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/VO_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/COB_0000026"/>
        <obo:IAO_0000115>Material entity that is manufactured to realize the vaccine function.</obo:IAO_0000115>
        <rdfs:label>vaccine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/VO_0000002 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/VO_0000002">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0600007"/>
        <obo:IAO_0000115>Process of administering a vaccine in vivo to a recipient (e.g., a human), with the intent to invoke a protective or therapeutic adaptive immune response.</obo:IAO_0000115>
        <rdfs:label>vaccination</rdfs:label>
    </owl:Class>
